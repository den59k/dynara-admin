// Demo schema for the dev-app. Related models so the panel can show off a
// list/CRUD page, a foreign-key `reference` field (Post.author -> User), and an
// ordered many-link (`Post.tags` — `@list` stores the relation as an array of
// ids and preserves its order).

model User {
  name     String
  email    String?
  age      Int
  role     String
  balance  Int
  birthday DateTime?
  schedule Json
  posts    Post[] @bind(Post.author)
}

model Post {
  title     String
  body      String?
  published Boolean
  author    User?
  tags      Tag[] @list
  labels    String[]
}

model Tag {
  title String
  posts Post[] @bind(Post.tags)
}
