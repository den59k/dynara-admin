// Demo schema for the dev-app. Two related models so the panel can show off a
// list/CRUD page plus a foreign-key `reference` field (Post.author -> User).

model User {
  name     String
  email    String?
  age      Int
  role     String
  balance  Int
  birthday DateTime?
  posts    Post[] @bind(Post.author)
}

model Post {
  title     String
  body      String?
  published Boolean
  author    User?
}
